{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Postgres": "",
    "Redis": ""
  },
  "Jwt": {
    "Issuer": "SocialHub",
    "Audience": "SocialHubClient",
    "Key": "",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 30
  },
  "Smtp": {
    "Host": "",
    "Port": 587,
    "Username": "",
    "Password": "",
    "FromEmail": "no-reply@socialhub.local",
    "FromName": "SocialHub",
    "UseStartTls": true
  },
  "AppUrls": {
    "EmailConfirmationUrl": "http://localhost:5173/confirm-email?userId={userId}&token={token}",
    "PasswordResetUrl": "http://localhost:5173/reset-password?email={email}&token={token}"
  },
  "RateLimiting": {
    "Login": { "PermitLimit": 5, "WindowSeconds": 60 },
    "Register": { "PermitLimit": 5, "WindowSeconds": 300 },
    "PasswordReset": { "PermitLimit": 5, "WindowSeconds": 300 }
  },
  "Storage": {
    "RootPath": "/var/socialhub/uploads",
    "TempFileTtlHours": 24,
    "ImageMaxDimension": 2048,
    "ThumbnailSize": 320
  },
  "Serilog": {
    "MinimumLevel": "Information"
  }
}